    "dataSources": {
        "ds_total_events": {
            "type": "ds.search",
            "options": {
                "query": "index=main (sourcetype=\"XmlWinEventLog:Microsoft-Windows-Sysmon/Operational\" OR sourcetype=suricata OR sourcetype=\"WinEventLog:Security\") | stats count as total_events",
                "queryParameters": {
                    "earliest": "$global_time.earliest$",
                    "latest": "$global_time.latest$"
                }
            }
        },
        "ds_ml_findings_count": {
            "type": "ds.search",
            "options": {
                "query": "index=main sourcetype=\"soc:ml:anomaly\" | stats count as ml_findings | append [| makeresults | eval ml_findings=0] | stats max(ml_findings) as ml_findings",
                "queryParameters": {
                    "earliest": "$global_time.earliest$",
                    "latest": "$global_time.latest$"
                }
            }
        },
        "ds_incident_count": {
            "type": "ds.search",
            "options": {
                "query": "index=main sourcetype=\"soc:ml:incident\" | stats count as incidents | append [| makeresults | eval incidents=0] | stats max(incidents) as incidents",
                "queryParameters": {
                    "earliest": "$global_time.earliest$",
                    "latest": "$global_time.latest$"
                }
            }
        },
        "ds_p1_count": {
            "type": "ds.search",
            "options": {
                "query": "index=main sourcetype=\"soc:ml:incident\" priority_level=\"P1\" | stats count as p1_count | append [| makeresults | eval p1_count=0] | stats max(p1_count) as p1_count",
                "queryParameters": {
                    "earliest": "$global_time.earliest$",
                    "latest": "$global_time.latest$"
                }
            }
        },
        "ds_risk_rating": {
            "type": "ds.search",
            "options": {
                "query": "index=main sourcetype=\"soc:ml:incident\" | eval sev_score=case(severity==\"Critical\", 4, severity==\"High\", 3, severity==\"Medium\", 2, severity==\"Low\", 1, true(), 0) | stats max(sev_score) as max_sev count(eval(priority_level==\"P1\")) as p1_count | eval risk_rating=case(max_sev>=4 OR p1_count>=2, \"CRITICAL\", max_sev>=3 OR p1_count>=1, \"HIGH\", max_sev>=2, \"MEDIUM\", true(), \"LOW\") | table risk_rating",
                "queryParameters": {
                    "earliest": "$global_time.earliest$",
                    "latest": "$global_time.latest$"
                }
            }
        },
        "ds_mitre_technique_count": {
            "type": "ds.search",
            "options": {
                "query": "index=main sourcetype=\"soc:ml:incident\" | stats dc(attack_technique) as unique_techniques | append [| makeresults | eval unique_techniques=0] | stats max(unique_techniques) as unique_techniques",
                "queryParameters": {
                    "earliest": "$global_time.earliest$",
                    "latest": "$global_time.latest$"
                }
            }
        },
        "ds_mttd": {
            "type": "ds.search",
            "options": {
                "query": "index=main sourcetype=\"soc:ml:incident\" | eval detect_lag=now()-_time | stats avg(detect_lag) as avg_lag | eval mttd=round(avg_lag/60, 0) | table mttd | append [| makeresults | eval mttd=0] | stats max(mttd) as mttd",
                "queryParameters": {
                    "earliest": "$global_time.earliest$",
                    "latest": "$global_time.latest$"
                }
            }
        },
        "ds_suricata_alert_count": {
            "type": "ds.search",
            "options": {
                "query": "index=main sourcetype=suricata event_type=alert | stats count as suricata_alerts | append [| makeresults | eval suricata_alerts=0] | stats max(suricata_alerts) as suricata_alerts",
                "queryParameters": {
                    "earliest": "$global_time.earliest$",
                    "latest": "$global_time.latest$"
                }
            }
        },
        "ds_severity_dist": {
            "type": "ds.search",
            "options": {
                "query": "index=main sourcetype=\"soc:ml:incident\" | stats count by severity | sort -count",
                "queryParameters": {
                    "earliest": "$global_time.earliest$",
                    "latest": "$global_time.latest$"
                }
            }
        },
        "ds_severity_breakdown": {
            "type": "ds.search",
            "options": {
                "query": "index=main sourcetype=\"soc:ml:incident\" | chart count by severity priority_level | addtotals fieldname=Total",
                "queryParameters": {
                    "earliest": "$global_time.earliest$",
                    "latest": "$global_time.latest$"
                }
            }
        },
        "ds_incident_timeline": {
            "type": "ds.search",
            "options": {
                "query": "index=main sourcetype=\"soc:ml:incident\" | timechart span=1h count by severity",
                "queryParameters": {
                    "earliest": "$global_time.earliest$",
                    "latest": "$global_time.latest$"
                }
            }
        },
        "ds_category_dist": {
            "type": "ds.search",
            "options": {
                "query": "index=main sourcetype=\"soc:ml:incident\" | eval incident_category=coalesce(incident_category, \"Unclassified\") | stats count by incident_category | sort -count",
                "queryParameters": {
                    "earliest": "$global_time.earliest$",
                    "latest": "$global_time.latest$"
                }
            }
        },
        "ds_anomaly_scores": {
            "type": "ds.search",
            "options": {
                "query": "index=main sourcetype=\"soc:ml:anomaly\" | timechart span=5m avg(anomaly_score) as \"Avg Score\" max(anomaly_score) as \"Max Score\"",
                "queryParameters": {
                    "earliest": "$global_time.earliest$",
                    "latest": "$global_time.latest$"
                }
            }
        },
        "ds_top_hosts": {
            "type": "ds.search",
            "options": {
                "query": "index=main sourcetype=\"soc:ml:incident\" | top limit=10 host | fields host count",
                "queryParameters": {
                    "earliest": "$global_time.earliest$",
                    "latest": "$global_time.latest$"
                }
            }
        },
        "ds_top_source_ips": {
            "type": "ds.search",
            "options": {
                "query": "index=main sourcetype=\"soc:ml:incident\" source_ip!=\"\" | top limit=10 source_ip | fields source_ip count",
                "queryParameters": {
                    "earliest": "$global_time.earliest$",
                    "latest": "$global_time.latest$"
                }
            }
        },
        "ds_mitre_by_tactic": {
            "type": "ds.search",
            "options": {
                "query": "index=main sourcetype=\"soc:ml:incident\" | eval tactic=mvindex(mitre_tactics, 0) | eval tactic=coalesce(tactic, \"Unknown\") | chart count over attack_technique by tactic | sort -count",
                "queryParameters": {
                    "earliest": "$global_time.earliest$",
                    "latest": "$global_time.latest$"
                }
            }
        },
        "ds_mitre_tactics": {
            "type": "ds.search",
            "options": {
                "query": "index=main sourcetype=\"soc:ml:incident\" | eval tactic=mvindex(mitre_tactics, 0) | search tactic=* | stats count by tactic | sort -count",
                "queryParameters": {
                    "earliest": "$global_time.earliest$",
                    "latest": "$global_time.latest$"
                }
            }
        },
        "ds_attack_chain": {
            "type": "ds.search",
            "options": {
                "query": "index=main sourcetype=\"soc:ml:incident\" | table _time host incident_type incident_category attack_technique severity priority_level timeline_stage | sort -priority_level _time",
                "queryParameters": {
                    "earliest": "$global_time.earliest$",
                    "latest": "$global_time.latest$"
                }
            }
        },
        "ds_mitre_coverage": {
            "type": "ds.search",
            "options": {
                "query": "index=main sourcetype=\"soc:ml:incident\" | stats count values(incident_type) as detection_rules first(severity) as severity by attack_technique | eval tactic=case(match(attack_technique, \"T1046\"), \"Discovery\", match(attack_technique, \"T1059\"), \"Execution\", match(attack_technique, \"T1110\"), \"Credential Access\", match(attack_technique, \"T1027\"), \"Defense Evasion\", match(attack_technique, \"T1218\"), \"Defense Evasion\", match(attack_technique, \"T1003\"), \"Credential Access\", match(attack_technique, \"T1048\"), \"Exfiltration\", match(attack_technique, \"T1204\"), \"Execution\", match(attack_technique, \"T1498\"), \"Impact\", match(attack_technique, \"T1566\"), \"Initial Access\", match(attack_technique, \"T1074\"), \"Collection\", match(attack_technique, \"T1078\"), \"Persistence\", true(), \"Unknown\") | table attack_technique tactic detection_rules count severity | sort tactic",
                "queryParameters": {
                    "earliest": "$global_time.earliest$",
                    "latest": "$global_time.latest$"
                }
            }
        },
        "ds_disposition_tp": {
            "type": "ds.search",
            "options": {
                "query": "index=main sourcetype=\"soc:ml:incident\" severity IN (\"Critical\", \"High\") | stats count as true_positives | append [| makeresults | eval true_positives=0] | stats max(true_positives) as true_positives",
                "queryParameters": {
                    "earliest": "$global_time.earliest$",
                    "latest": "$global_time.latest$"
                }
            }
        },
        "ds_disposition_fp": {
            "type": "ds.search",
            "options": {
                "query": "index=main sourcetype=\"soc:ml:incident\" severity=\"Low\" | stats count as false_positives | append [| makeresults | eval false_positives=0] | stats max(false_positives) as false_positives",
                "queryParameters": {
                    "earliest": "$global_time.earliest$",
                    "latest": "$global_time.latest$"
                }
            }
        },
        "ds_disposition_pending": {
            "type": "ds.search",
            "options": {
                "query": "index=main sourcetype=\"soc:ml:incident\" severity=\"Medium\" | stats count as pending | append [| makeresults | eval pending=0] | stats max(pending) as pending",
                "queryParameters": {
                    "earliest": "$global_time.earliest$",
                    "latest": "$global_time.latest$"
                }
            }
        },
        "ds_sigma_matches": {
            "type": "ds.search",
            "options": {
                "query": "index=main sourcetype=\"soc:ml:incident\" sigma_rule_id!=\"\" | table _time sigma_rule_id sigma_rule_title incident_type incident_category severity host attack_technique | sort -_time",
                "queryParameters": {
                    "earliest": "$global_time.earliest$",
                    "latest": "$global_time.latest$"
                }
            }
        },
        "ds_feature_importance": {
            "type": "ds.search",
            "options": {
                "query": "index=main sourcetype=\"soc:ml:anomaly\" | stats avg(powershell_count) as PowerShell avg(unique_dest_ports) as Unique_Ports avg(connection_count) as Connections avg(suricata_alert_count) as IDS_Alerts avg(login_failure_count) as Login_Failures avg(rare_process_count) as Rare_Procs avg(high_risk_process_count) as HighRisk_Procs avg(encoded_command_count) as Encoded_Cmds avg(file_create_count) as File_Creates avg(dns_query_count) as DNS_Queries avg(external_connection_count) as External_Conns avg(lolbin_count) as LOLBins | transpose 0 header_field=none column_name=Feature | rename \"row 1\" as avg_value | sort -avg_value",
                "queryParameters": {
                    "earliest": "$global_time.earliest$",
                    "latest": "$global_time.latest$"
                }
            }
        },
        "ds_ml_findings_detail": {
            "type": "ds.search",
            "options": {
                "query": "index=main sourcetype=\"soc:ml:anomaly\" | table _time host source_ip severity anomaly_score reason powershell_count unique_dest_ports connection_count suricata_alert_count login_failure_count | sort -anomaly_score",
                "queryParameters": {
                    "earliest": "$global_time.earliest$",
                    "latest": "$global_time.latest$"
                }
            }
        },
        "ds_anomaly_severity": {
            "type": "ds.search",
            "options": {
                "query": "index=main sourcetype=\"soc:ml:anomaly\" | stats count by severity | sort -count",
                "queryParameters": {
                    "earliest": "$global_time.earliest$",
                    "latest": "$global_time.latest$"
                }
            }
        },
        "ds_sigma_rule_count": {
            "type": "ds.search",
            "options": {
                "query": "index=main sourcetype=\"soc:ml:incident\" sigma_rule_id!=\"\" | stats dc(sigma_rule_id) as sigma_rules | append [| makeresults | eval sigma_rules=0] | stats max(sigma_rules) as sigma_rules",
                "queryParameters": {
                    "earliest": "$global_time.earliest$",
                    "latest": "$global_time.latest$"
                }
            }
        },
        "ds_priority_dist": {
            "type": "ds.search",
            "options": {
                "query": "index=main sourcetype=\"soc:ml:incident\" | stats count by priority_level | sort priority_level",
                "queryParameters": {
                    "earliest": "$global_time.earliest$",
                    "latest": "$global_time.latest$"
                }
            }
        },
        "ds_sysmon_timeline": {
            "type": "ds.search",
            "options": {
                "query": "index=main sourcetype=\"XmlWinEventLog:Microsoft-Windows-Sysmon/Operational\" | eval EventName=case(EventCode==1, \"Process Create\", EventCode==3, \"Network Connect\", EventCode==7, \"Image Load\", EventCode==11, \"File Create\", EventCode==13, \"Registry\", EventCode==22, \"DNS Query\", true(), \"Other\") | timechart span=5m count by EventName",
                "queryParameters": {
                    "earliest": "$global_time.earliest$",
                    "latest": "$global_time.latest$"
                }
            }
        },
        "ds_sysmon_processes": {
            "type": "ds.search",
            "options": {
                "query": "index=main sourcetype=\"XmlWinEventLog:Microsoft-Windows-Sysmon/Operational\" EventCode=1 | table _time Image ParentImage User CommandLine | head 30",
                "queryParameters": {
                    "earliest": "$global_time.earliest$",
                    "latest": "$global_time.latest$"
                }
            }
        },
        "ds_suricata_timeline": {
            "type": "ds.search",
            "options": {
                "query": "index=main sourcetype=suricata event_type=alert | eval sev=coalesce(alert.severity, severity, 3) | eval sev_name=case(sev==1, \"Critical\", sev==2, \"High\", sev==3, \"Medium\", true(), \"Low\") | timechart span=5m count by sev_name",
                "queryParameters": {
                    "earliest": "$global_time.earliest$",
                    "latest": "$global_time.latest$"
                }
            }
        },
        "ds_suricata_top_sigs": {
            "type": "ds.search",
            "options": {
                "query": "index=main sourcetype=suricata event_type=alert | eval sig=coalesce(alert.signature, signature, \"Unknown\") | top limit=10 sig | rename sig as Signature",
                "queryParameters": {
                    "earliest": "$global_time.earliest$",
                    "latest": "$global_time.latest$"
                }
            }
        },
        "ds_auth_failures": {
            "type": "ds.search",
            "options": {
                "query": "index=main sourcetype=\"WinEventLog:Security\" EventCode=4625 | timechart span=5m count as failed_logins",
                "queryParameters": {
                    "earliest": "$global_time.earliest$",
                    "latest": "$global_time.latest$"
                }
            }
        },
        "ds_network_connections": {
            "type": "ds.search",
            "options": {
                "query": "index=main sourcetype=\"XmlWinEventLog:Microsoft-Windows-Sysmon/Operational\" EventCode=3 | eval direction=if(Initiated==\"true\", \"Outbound\", \"Inbound\") | timechart span=5m count by direction",
                "queryParameters": {
                    "earliest": "$global_time.earliest$",
                    "latest": "$global_time.latest$"
                }
            }
        },
        "ds_dns_queries": {
            "type": "ds.search",
            "options": {
                "query": "index=main sourcetype=\"XmlWinEventLog:Microsoft-Windows-Sysmon/Operational\" EventCode=22 | eval domain=coalesce(QueryName, \"Unknown\") | top limit=15 domain | fields domain count",
                "queryParameters": {
                    "earliest": "$global_time.earliest$",
                    "latest": "$global_time.latest$"
                }
            }
        },
        "ds_incident_detail": {
            "type": "ds.search",
            "options": {
                "query": "index=main sourcetype=\"soc:ml:incident\" | table _time incident_type incident_category severity priority_level priority_score attack_technique host source_ip confidence sigma_rule_id | sort -priority_score",
                "queryParameters": {
                    "earliest": "$global_time.earliest$",
                    "latest": "$global_time.latest$"
                }
            }
        },
        "ds_remediation": {
            "type": "ds.search",
            "options": {
                "query": "index=main sourcetype=\"soc:ml:incident\" | eval remediation=mvjoin(remediation_actions, \" | \") | table _time incident_type attack_technique severity host remediation | sort -severity",
                "queryParameters": {
                    "earliest": "$global_time.earliest$",
                    "latest": "$global_time.latest$"
                }
            }
        },
        "ds_thehive_status": {
            "type": "ds.search",
            "options": {
                "query": "index=main sourcetype=\"soc:ml:incident\" | table _time incident_type severity host thehive_case_id thehive_status priority_level | sort -_time",
                "queryParameters": {
                    "earliest": "$global_time.earliest$",
                    "latest": "$global_time.latest$"
                }
            }
        },
        "ds_data_sources_ingest": {
            "type": "ds.search",
            "options": {
                "query": "index=main | eval src=case(sourcetype==\"XmlWinEventLog:Microsoft-Windows-Sysmon/Operational\", \"Sysmon\", sourcetype==\"suricata\", \"Suricata\", sourcetype==\"WinEventLog:Security\", \"WinSecurity\", match(sourcetype, \"soc:ml\"), \"ML Engine\", true(), \"Other\") | timechart span=1h count by src",
                "queryParameters": {
                    "earliest": "$global_time.earliest$",
                    "latest": "$global_time.latest$"
                }
            }
        },
        "ds_data_source_count": {
            "type": "ds.search",
            "options": {
                "query": "index=main | stats dc(sourcetype) as data_sources",
                "queryParameters": {
                    "earliest": "$global_time.earliest$",
                    "latest": "$global_time.latest$"
                }
            }
        },
        "ds_ti_ips": {
            "type": "ds.search",
            "options": {
                "query": "index=main sourcetype=\"soc:ml:incident\" source_ip!=\"\" | dedup source_ip | eval reputation=\"Pending TI\", threat_score=\"N/A\", ioc_source=\"Connect AbuseIPDB/OTX\" | table source_ip host incident_type severity reputation threat_score ioc_source",
                "queryParameters": {
                    "earliest": "$global_time.earliest$",
                    "latest": "$global_time.latest$"
                }
            }
        },
        "ds_ti_hashes": {
            "type": "ds.search",
            "options": {
                "query": "index=main sourcetype=\"XmlWinEventLog:Microsoft-Windows-Sysmon/Operational\" (EventCode=1 OR EventCode=7) Hashes=* | eval file_hash=Hashes | eval reputation=\"Pending TI\", vt_score=\"N/A\" | dedup file_hash | table _time Image file_hash reputation vt_score | head 15",
                "queryParameters": {
                    "earliest": "$global_time.earliest$",
                    "latest": "$global_time.latest$"
                }
            }
        },
        "ds_open_incidents": {
            "type": "ds.search",
            "options": {
                "query": "index=main sourcetype=\"soc:ml:incident\" | eval status=coalesce(thehive_status, \"Open\") | search status!=\"Resolved\" | table _time incident_type incident_category severity host attack_technique status | sort -severity",
                "queryParameters": {
                    "earliest": "$global_time.earliest$",
                    "latest": "$global_time.latest$"
                }
            }
        },
        "ds_audit_log": {
            "type": "ds.search",
            "options": {
                "query": "index=main (sourcetype=\"soc:ml:anomaly\" OR sourcetype=\"soc:ml:incident\") | eval action=case(sourcetype==\"soc:ml:anomaly\", \"ML Detection\", sourcetype==\"soc:ml:incident\", \"Incident Correlation\") | table _time action incident_type severity host attack_technique sigma_rule_id priority_level | sort -_time",
                "queryParameters": {
                    "earliest": "$global_time.earliest$",
                    "latest": "$global_time.latest$"
                }
            }
        }
    },

